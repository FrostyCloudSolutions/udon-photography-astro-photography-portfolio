---
import siteConfig from '../../site.config.mjs';

const title = siteConfig.title;

const base = import.meta.env.BASE_URL;

const menuItems = [
  { name: 'Home', link: `${base}` },
  { name: 'Portfolio', link: `${base}collections` },
  { name: 'Journal', link: `${base}journal` },
  { name: 'About', link: `${base}about` },
  { name: 'Investment', link: `${base}investment` },
  { name: 'Inquire', link: `${base}inquire` },
];
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400..700&display=swap"
	rel="stylesheet"
/>

<nav
	x-data="{ isOpen: false, scrolled: false }"
	@scroll.window="scrolled = window.scrollY > 50"
	class="fixed top-0 left-0 w-full z-50 transition-all duration-300"
	:class="scrolled ? 'py-3 bg-white shadow-sm' : 'py-5 bg-transparent'"
>
	<div class="container mx-auto flex justify-between items-center">
		<a href={base} id="logo" class="text-2xl md:text-4xl font-semibold tracking-tight">
			{title}
		</a>

		
		
		<!-- Desktop Menu -->
		<div class="hidden md:flex space-x-8">
			<a href={base} class="nav-link relative after:content-[''] after:absolute after:left-0 after:bottom-[-2px] after:h-[2px] after:bg-black after:w-0 hover:after:w-full transition-all">Home</a>

			<!-- Portfolio Dropdown -->
			<div class="relative" x-data="{ open: false }" @mouseenter="open = true" @mouseleave="open = false">
				<a href={`${base}collections`} class="nav-link relative after:content-[''] after:absolute after:left-0 after:bottom-[-2px] after:h-[2px] after:bg-black after:w-0 hover:after:w-full transition-all">Portfolio</a>
				<div x-show="open" class="absolute top-full left-0 bg-white shadow-md py-2 min-w-48 z-50">
					<a href={`${base}collections/in-home`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">In-Home</a>
					<a href={`${base}collections/outdoor`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Outdoor</a>
					<a href={`${base}collections/maternity`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Maternity</a>
					<a href={`${base}collections/pet`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Pet</a>
					<a href={`${base}collections/parties-and-events`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Parties & Events</a>
					<a href={`${base}collections/fine-art`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Fine Art Projects</a>
					<a href={`${base}collections/commercial`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Commercial Work</a>
					<a href={`${base}collections/workshops`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Workshops</a>
				</div>
			</div>

			<!-- Journal Dropdown -->
			<div class="relative" x-data="{ open: false }" @mouseenter="open = true" @mouseleave="open = false">
				<a href={`${base}journal`} class="nav-link relative after:content-[''] after:absolute after:left-0 after:bottom-[-2px] after:h-[2px] after:bg-black after:w-0 hover:after:w-full transition-all">Journal</a>
				<div x-show="open" class="absolute top-full left-0 bg-white shadow-md py-2 min-w-48 z-50">
					<a href={`${base}journal/an-ordinary-afternoon`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">An Ordinary Afternoon</a>
					<a href={`${base}journal/turning-one`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Turning One</a>
					<a href={`${base}journal/waiting-for-you`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Waiting for You</a>
					<a href={`${base}journal/in-red`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">In Red</a>
				</div>
			</div>

			<a href={`${base}about`} class="nav-link relative after:content-[''] after:absolute after:left-0 after:bottom-[-2px] after:h-[2px] after:bg-black after:w-0 hover:after:w-full transition-all">About</a>
			<a href={`${base}investment`} class="nav-link relative after:content-[''] after:absolute after:left-0 after:bottom-[-2px] after:h-[2px] after:bg-black after:w-0 hover:after:w-full transition-all">Investment</a>
			<a href={`${base}inquire`} class="nav-link relative after:content-[''] after:absolute after:left-0 after:bottom-[-2px] after:h-[2px] after:bg-black after:w-0 hover:after:w-full transition-all">Inquire</a>
		</div>
		<!-- Mobile Menu Button -->
		<button @click="isOpen = !isOpen" class="md:hidden text-gray-800 focus:outline-none">
			<svg x-show="!isOpen" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M4 6h16M4 12h16M4 18h16"></path>
			</svg>
			<svg x-show="isOpen" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M6 18L18 6M6 6l12 12"></path>
			</svg>
		</button>
	</div>
	<!-- Mobile Menu -->
	<div x-show="isOpen" class="md:hidden absolute top-full left-0 w-full bg-white shadow-md">
		<div class="flex flex-col py-4 px-6 space-y-4">
			<a href={base} class="text-lg" @click="isOpen = false">Home</a>

			<!-- Portfolio Mobile Dropdown -->
			<div x-data="{ portfolioOpen: false }">
				<button @click="portfolioOpen = !portfolioOpen" class="text-lg flex justify-between w-full">
					Portfolio
					<span x-text="portfolioOpen ? '−' : '+'"></span>
				</button>
				<div x-show="portfolioOpen" class="flex flex-col pl-4 mt-2 space-y-2">
					<a href={`${base}collections/in-home`} class="text-sm text-gray-600" @click="isOpen = false">In-Home</a>
					<a href={`${base}collections/outdoor`} class="text-sm text-gray-600" @click="isOpen = false">Outdoor</a>
					<a href={`${base}collections/maternity`} class="text-sm text-gray-600" @click="isOpen = false">Maternity</a>
					<a href={`${base}collections/pet`} class="text-sm text-gray-600" @click="isOpen = false">Pet</a>
					<a href={`${base}collections/parties-and-events`} class="text-sm text-gray-600" @click="isOpen = false">Parties & Events</a>
					<a href={`${base}collections/fine-art`} class="text-sm text-gray-600" @click="isOpen = false">Fine Art Projects</a>
					<a href={`${base}collections/commercial`} class="text-sm text-gray-600" @click="isOpen = false">Commercial Work</a>
					<a href={`${base}collections/workshops`} class="text-sm text-gray-600" @click="isOpen = false">Workshops</a>
				</div>
			</div>

			<!-- Journal Mobile Dropdown -->
			<div x-data="{ journalOpen: false }">
				<button @click="journalOpen = !journalOpen" class="text-lg flex justify-between w-full">
					Journal
					<span x-text="journalOpen ? '−' : '+'"></span>
				</button>
				<div x-show="journalOpen" class="flex flex-col pl-4 mt-2 space-y-2">
					<a href={`${base}journal/an-ordinary-afternoon`} class="text-sm text-gray-600" @click="isOpen = false">An Ordinary Afternoon</a>
					<a href={`${base}journal/turning-one`} class="text-sm text-gray-600" @click="isOpen = false">Turning One</a>
					<a href={`${base}journal/waiting-for-you`} class="text-sm text-gray-600" @click="isOpen = false">Waiting for You</a>
					<a href={`${base}journal/in-red`} class="text-sm text-gray-600" @click="isOpen = false">In Red</a>
				</div>
			</div>

			<a href={`${base}about`} class="text-lg" @click="isOpen = false">About</a>
			<a href={`${base}investment`} class="text-lg" @click="isOpen = false">Investment</a>
			<a href={`${base}inquire`} class="text-lg" @click="isOpen = false">Inquire</a>
		</div>
	</div>
	</nav>