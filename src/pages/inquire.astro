---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
    <section class="pt-32 pb-20">
        <div class="container-custom">
            <div class="max-w-2xl mx-auto text-center mb-16">
                <h1 class="text-4xl md:text-5xl font-bold mb-4">Inquire</h1>
                <p class="text-gray-600">I'd love to hear from you. Fill out the form below and I'll be in touch soon.</p>
            </div>

            <form action="https://formspree.io/f/XXXXXXXX" method="POST" class="max-w-xl mx-auto space-y-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                    <input type="text" name="name" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-black" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input type="email" name="email" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-black" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Type of Session</label>
                    <select name="session_type" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-black">
                        <option value="">Select a session type</option>
                        <option value="in-home">In-Home</option>
                        <option value="outdoor">Outdoor</option>
                        <option value="maternity">Maternity</option>
                        <option value="pet">Pet</option>
                        <option value="parties-events">Parties & Events</option>
                        <option value="fine-art">Fine Art Projects</option>
                        <option value="commercial">Commercial Work</option>
                        <option value="workshops">Workshops</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
                    <textarea name="message" rows="5" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-black"></textarea>
                </div>
                <button type="submit" class="w-full bg-black text-white py-3 rounded-lg hover:bg-gray-800 transition-colors">
                    Send Inquiry
                </button>
            </form>
        </div>
    </section>
</MainLayout>